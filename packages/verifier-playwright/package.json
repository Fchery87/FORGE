{
  "name": "@forge-core/verifier-playwright",
  "version": "0.1.0",
  "description": "Playwright browser verifier plugin for the Forge AI coding agent",
  "keywords": [
    "forge",
    "ai",
    "coding-agent"
  ],
  "author": "Forge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fchery87/FORGE"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@forge-core/types": "^0.1.0"
  },
  "peerDependencies": {
    "playwright": ">=1.50.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
