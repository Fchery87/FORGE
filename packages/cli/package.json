{
  "name": "@forge-core/cli",
  "version": "0.1.0",
  "description": "Command-line interface for the Forge AI coding agent",
  "keywords": [
    "forge",
    "ai",
    "coding-agent"
  ],
  "author": "Forge",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fchery87/FORGE"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "forge": "./dist/bin/forge.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "postbuild": "chmod +x dist/bin/forge.mjs || true",
    "test": "vitest run",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@forge-core/adapter-claude-code": "^0.1.0",
    "@forge-core/adapter-codex": "^0.1.0",
    "@forge-core/adapter-opencode": "^0.1.0",
    "@forge-core/core": "^0.1.0",
    "@forge-core/types": "^0.1.0",
    "@forge-core/verifier-playwright": "^0.1.0",
    "@forge-core/verifier-test-runner": "^0.1.0",
    "commander": "^14.0.3",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
