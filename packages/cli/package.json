{
  "name": "@forge-agent/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forge": "./dist/bin/forge.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "chmod +x dist/bin/forge.js || true",
    "test": "vitest run",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@forge-agent/core": "*",
    "@forge-agent/types": "*",
    "commander": "^12.0.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "*"
  }
}
