{
  "name": "@forge-agent/core",
  "version": "0.1.0",
  "description": "Core orchestration engine for the Forge AI coding agent",
  "keywords": [
    "forge",
    "ai",
    "coding-agent"
  ],
  "author": "Forge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forge-agent/forge"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
