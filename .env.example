# ============================================================
# Forge — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.
#
# Forge itself reads no environment variables directly.
# These variables are consumed by the executor adapters
# and verifier adapters that Forge dispatches work to.
# ============================================================


# ------------------------------------------------------------
# Claude Code Adapter (@forge-agent/adapter-claude-code)
# ------------------------------------------------------------
# Required when executor.name = "claude-code" in forge config.
# The claude CLI must be authenticated; this key is used by
# the underlying Anthropic SDK when the CLI calls the API.
#
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by the Claude Code adapter.
# Defaults to the model configured in forge config (adapter.model).
# Values: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
#
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: base URL override for Anthropic API (e.g. for proxies).
#
# ANTHROPIC_BASE_URL=https://api.anthropic.com


# ------------------------------------------------------------
# OpenCode Adapter (@forge-agent/adapter-opencode)
# ------------------------------------------------------------
# Required when executor.name = "opencode" in forge config.
# OpenCode reads its own config file (opencode.config.json)
# which the installer writes into the project root.
# Set whichever provider key OpenCode is configured to use.
#
# OPENAI_API_KEY=sk-...
# OPENCODE_MODEL=gpt-4o


# ------------------------------------------------------------
# Playwright Verifier (@forge-agent/verifier-playwright)
# ------------------------------------------------------------
# Required when verifier.name = "playwright" in forge config.
# These control what URL and auth the browser verifier targets.
#
# Base URL of the running application to verify against.
# Must be reachable when `forge qa` is run.
#
# FORGE_BASE_URL=http://localhost:3000

# Optional: path to a Playwright storage state file for
# authenticated sessions (cookies, localStorage).
# Generate with: npx playwright codegen --save-storage=auth.json
#
# FORGE_SESSION_FILE=.forge/qa/auth.json


# ------------------------------------------------------------
# Forge Runtime (advanced)
# ------------------------------------------------------------
# Override the directory Forge uses for state storage.
# Defaults to .forge/ in the nearest ancestor containing .forge/.
# Only set this if you are running Forge in CI or a non-standard
# working directory layout.
#
# FORGE_DIR=/absolute/path/to/.forge

# Log level for the CLI. Values: debug, info, warn, error
# The --verbose flag sets this to debug at runtime.
#
# FORGE_LOG_LEVEL=info
